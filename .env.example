# .env.example — copy to .env.local and fill in values
# DO NOT commit .env.local to version control

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# Supabase (cloud sync)
# Get these from your Supabase project → Settings → API
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never use NEXT_PUBLIC_

# ─────────────────────────────────────────
# Google OAuth + Calendar
# Get these from Google Cloud Console → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3000/api/google/callback
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ─────────────────────────────────────────
# Google Gemini AI (AI scheduling assistant)
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─────────────────────────────────────────
# Session encryption (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────
SESSION_SECRET=your-32-char-minimum-secret-here
